---
import ThemePicker from './ThemePicker.astro';

const year = new Date().getFullYear();
---

<footer class="border-t border-ctp-surface0 mt-16">
  <div class="max-w-3xl mx-auto px-4 py-6 text-sm text-ctp-overlay0 flex flex-col sm:flex-row items-center justify-between gap-2">
    <span>&copy; {year} quz.ma &middot; Code: MIT &middot; Content: CC BY 4.0</span>
    <div class="flex items-center gap-3">
      <a
        href="https://github.com/DarkoKuzmanovic/quz.ma"
        class="text-ctp-overlay1 hover:text-ctp-green transition-colors"
      >
        source
      </a>
      <ThemePicker />
    </div>
  </div>
</footer>
