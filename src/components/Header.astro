---
const navItems = [
  { label: 'BLOG', href: '/blog', icon: '»' },
  { label: 'TIL', href: '/til', icon: '»' },
  { label: 'PROJECTS', href: '/projects', icon: '»' },
  { label: 'ABOUT', href: '/about', icon: '»' },
  { label: 'USES', href: '/uses', icon: '»' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-ctp-base/90 backdrop-blur-sm border-b border-ctp-surface0">
  <nav class="max-w-3xl mx-auto px-4 py-3 flex items-center justify-between">
    <a href="/" class="text-ctp-green hover:text-ctp-mauve transition-colors tracking-wider">
      QUZ.MA
    </a>

    <!-- Desktop nav -->
    <ul class="hidden sm:flex gap-5 text-xs uppercase tracking-wider">
      {navItems.map(({ label, href, icon }) => (
        <li>
          <a
            href={href}
            class:list={[
              'transition-colors',
              currentPath.startsWith(href)
                ? 'text-ctp-mauve'
                : 'text-ctp-overlay1 hover:text-ctp-text',
            ]}
          >
            <span class="text-ctp-surface2">{icon}</span> {label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Mobile hamburger button -->
    <button
      id="menu-toggle"
      class="sm:hidden text-ctp-overlay1 hover:text-ctp-text transition-colors"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <svg id="menu-icon-open" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="menu-icon-close" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <ul id="mobile-menu" class="hidden sm:hidden px-4 pb-3 text-xs uppercase tracking-wider border-t border-ctp-surface0">
    {navItems.map(({ label, href, icon }) => (
      <li>
        <a
          href={href}
          class:list={[
            'block py-2 transition-colors',
            currentPath.startsWith(href)
              ? 'text-ctp-mauve'
              : 'text-ctp-overlay1 hover:text-ctp-text',
          ]}
        >
          <span class="text-ctp-surface2">{icon}</span> {label}
        </a>
      </li>
    ))}
  </ul>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const iconOpen = document.getElementById('menu-icon-open');
  const iconClose = document.getElementById('menu-icon-close');

  toggle?.addEventListener('click', () => {
    const isOpen = !menu?.classList.contains('hidden');
    menu?.classList.toggle('hidden');
    iconOpen?.classList.toggle('hidden');
    iconClose?.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(!isOpen));
  });

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      menu.classList.add('hidden');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
    });
  });
</script>
