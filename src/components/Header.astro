---
import { GITHUB_URL } from '../consts';

const navItems = [
  { label: 'WORK', href: '/projects' },
  { label: 'ABOUT', href: '/about' },
];

const currentPath = Astro.url.pathname;
---

<header class="border-b border-ctp-surface0">
  <nav class="max-w-3xl mx-auto px-4 py-3 flex items-center justify-between">
    <a href="/" class="text-ctp-green hover:text-ctp-mauve transition-colors tracking-wider">
      QUZ.MA
    </a>

    <ul class="flex gap-5 text-xs uppercase tracking-wider">
      {navItems.map(({ label, href }) => (
        <li>
          <a
            href={href}
            class:list={[
              'transition-colors',
              currentPath.startsWith(href)
                ? 'text-ctp-mauve'
                : 'text-ctp-overlay1 hover:text-ctp-text',
            ]}
          >
            <span class="text-ctp-surface2">»</span> {label}
          </a>
        </li>
      ))}
      <li>
        <a href={GITHUB_URL} class="text-ctp-overlay1 hover:text-ctp-text transition-colors">
          <span class="text-ctp-surface2">»</span> GITHUB&nbsp;↗
        </a>
      </li>
    </ul>
  </nav>
</header>
