---
interface Props {
  name: string;
  description: string;
  stack: string[];
  repo?: string;
  url?: string;
}

const { name, description, stack, repo, url } = Astro.props;
---

<li class="py-5 border-t border-ctp-surface0 first:border-t-0 first:pt-1">
  <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
    {repo ? (
      <a href={repo} class="text-ctp-green hover:text-ctp-mauve transition-colors">
        {name}
      </a>
    ) : (
      <span class="text-ctp-green">{name}</span>
    )}
    <span class="text-xs text-ctp-overlay0">{stack.join(' · ')}</span>
  </div>
  <p class="text-sm text-ctp-subtext0 mt-1.5 max-w-xl">{description}</p>
  {url && (
    <a href={url} class="inline-block mt-1.5 text-xs text-ctp-overlay1 hover:text-ctp-green transition-colors">
      {url.replace('https://', '')} &rarr;
    </a>
  )}
</li>
