---
const themes = [
  { id: 'catppuccin-mocha', name: 'Catppuccin Mocha', accent: '#cba6f7' },
  { id: 'dracula', name: 'Dracula', accent: '#bd93f9' },
  { id: 'gruvbox', name: 'Gruvbox Dark', accent: '#fabd2f' },
  { id: 'nord', name: 'Nord', accent: '#88c0d0' },
  { id: 'solarized', name: 'Solarized Dark', accent: '#268bd2' },
  { id: 'tokyo-night', name: 'Tokyo Night', accent: '#7aa2f7' },
];
---

<div class="relative inline-block" id="theme-picker">
  <button
    id="theme-toggle"
    class="w-5 h-5 rounded-full border-2 border-ctp-surface2 hover:border-ctp-overlay1 transition-colors cursor-pointer"
    style="background-color: var(--color-ctp-mauve);"
    aria-label="Change theme"
    title="Change theme"
  ></button>

  <div
    id="theme-popup"
    class="hidden absolute bottom-8 right-0 bg-ctp-mantle border border-ctp-surface0 rounded-lg p-2 shadow-lg min-w-[160px] z-50"
  >
    {themes.map(({ id, name, accent }) => (
      <button
        class="theme-option flex items-center gap-2 w-full px-2 py-1.5 rounded text-xs text-ctp-overlay1 hover:text-ctp-text hover:bg-ctp-surface0 transition-colors cursor-pointer text-left"
        data-theme={id}
      >
        <span class="w-3 h-3 rounded-full shrink-0" style={`background-color: ${accent};`}></span>
        {name}
      </button>
    ))}
  </div>
</div>

