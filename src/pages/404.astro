---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="404">
  <div class="flex flex-col items-center justify-center py-20 text-center">
    <h1 class="text-[44px] leading-none text-ctp-red mb-6">404</h1>
    <p class="text-ctp-overlay1 mb-6 text-sm">
      <span class="text-ctp-red">░ FILE NOT FOUND</span>
    </p>
    <a href="/" class="text-xs text-ctp-green hover:text-ctp-mauve transition-colors">
      &larr; RETURN HOME
    </a>
  </div>
</BaseLayout>
