---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectRow from '../components/ProjectRow.astro';
import { PROMPT_PREFIX, GITHUB_URL, SELECTED_PROJECTS } from '../consts';

const all = await getCollection('projects');
const byId = new Map(all.map((p) => [p.id, p]));
const selected = SELECTED_PROJECTS.map((id) => byId.get(id)).filter(
  (p) => p !== undefined,
);
---

<BaseLayout title="Home">
  <section class="mb-16 mt-4" aria-label="Introduction">
    <p class="text-ctp-green text-sm tracking-widest mb-8">
      {PROMPT_PREFIX} QUZ.MA<span aria-hidden="true" class="cursor-blink">█</span>
    </p>
    <h1 class="text-2xl sm:text-3xl text-ctp-text tracking-tight">
      Darko Kuzmanovic
    </h1>
    <p class="mt-4 text-base sm:text-lg text-ctp-subtext1 max-w-xl">
      Late-night tinkerer building tools for coding agents, terminals, and the
      occasional small app.
    </p>
    <p class="mt-3 text-sm text-ctp-subtext0 max-w-xl">
      Most of my recent work is around Pi: orchestration, model tooling, and
      small utilities that make coding agents more useful.
    </p>
  </section>

  <section class="mb-14" aria-labelledby="selected-work">
    <h2 class="text-sm text-ctp-mauve mb-2" id="selected-work">
      ░&nbsp; SELECTED WORK
    </h2>
    <ul>
      {selected.map((project) => (
        <ProjectRow
          name={project.data.name}
          description={project.data.description}
          stack={project.data.stack}
          repo={project.data.repo}
          url={project.data.url}
        />
      ))}
    </ul>
    <a
      href={GITHUB_URL}
      class="inline-block mt-5 text-xs text-ctp-overlay1 hover:text-ctp-green transition-colors"
    >
      ── VIEW MORE WORK ON GITHUB &rarr;
    </a>
  </section>

  <section class="mb-14" aria-labelledby="a-note">
    <h2 class="text-sm text-ctp-mauve mb-4" id="a-note">
      ░&nbsp; A NOTE
    </h2>
    <p class="text-sm text-ctp-subtext0 max-w-xl">
      I have spent years building things mostly for myself, my work, or small
      communities. I am now making more of that work public and documenting
      what I learn along the way.
    </p>
  </section>

  <section aria-labelledby="elsewhere">
    <h2 class="text-sm text-ctp-mauve mb-4" id="elsewhere">
      ░&nbsp; ELSEWHERE
    </h2>
    <ul class="text-sm">
      <li>
        <a
          href={GITHUB_URL}
          class="text-ctp-green hover:text-ctp-mauve transition-colors"
        >
          github.com/DarkoKuzmanovic
        </a>
      </li>
    </ul>
  </section>
</BaseLayout>
