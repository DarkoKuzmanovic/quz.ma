---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectRow from '../components/ProjectRow.astro';
import { SELECTED_PROJECTS } from '../consts';

const all = await getCollection('projects');
const byId = new Map(all.map((p) => [p.id, p]));
const featured = SELECTED_PROJECTS.map((id) => byId.get(id)).filter(
  (p) => p !== undefined,
);
const rest = all
  .filter((p) => !SELECTED_PROJECTS.includes(p.id))
  .sort((a, b) => a.data.name.localeCompare(b.data.name));
---

<BaseLayout
  title="Projects"
  description="Software projects by Darko Kuzmanovic: Pi extensions, terminal tooling, and small apps."
>
  <h1 class="text-lg text-ctp-mauve mb-4">
    ░&nbsp; PROJECTS
  </h1>
  <p class="text-sm text-ctp-subtext0 mb-6 max-w-xl">
    Things I have built and maintain. Selected work first, the rest below.
  </p>
  <ul>
    {[...featured, ...rest].map((project) => (
      <ProjectRow
        name={project.data.name}
        description={project.data.description}
        stack={project.data.stack}
        repo={project.data.repo}
        url={project.data.url}
      />
    ))}
  </ul>
</BaseLayout>
